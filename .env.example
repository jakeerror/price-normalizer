# Copy to .env for docker compose. .env is git-ignored.

# --- Postgres ---
DB_USER=pricenorm
DB_PASSWORD=pricenorm
DB_NAME=pricenorm

# --- Auth ---
# Generate a strong secret, e.g. `openssl rand -hex 32`
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=60m

# --- Matching thresholds (SPEC §5.5) ---
MATCH_HIGH=0.9
MATCH_LOW=0.6

# --- Frontend (baked at build time) ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
