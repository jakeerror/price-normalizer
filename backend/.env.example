# Copy to .env and fill in. .env is git-ignored.

NODE_ENV=development
PORT=8000

# --- Postgres ---
DB_HOST=db
DB_PORT=5432
DB_USER=pricenorm
DB_PASSWORD=pricenorm
DB_NAME=pricenorm

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Auth ---
# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=60m

# --- Matching thresholds (SPEC §5.5) ---
MATCH_HIGH=0.90
MATCH_LOW=0.60
